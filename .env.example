# DeepSeek API key
DEEPSEEK_API_KEY=sk-...

# GitHub fine-grained PAT (contents read/write, single repo)
GITHUB_TOKEN=github_pat_...

# GitHub repository info (used by file tools)
GITHUB_REPO_OWNER=LikeDreamwalker
GITHUB_REPO_NAME=Aftrbrez

# Demo mode: redirect memory/ reads to a remote benchmark dataset.
# Set to "true" to read pre-seeded persona data from BENCHMARK_BASE_URL.
# Leave unset or "false" for normal operation.
# BENCHMARK_BASE_URL is optional — defaults to the official benchmark repo.
DEMO_MODE=false
# BENCHMARK_BASE_URL=https://raw.githubusercontent.com/previously-lab/benchmark-data/main
