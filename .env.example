# DeepSeek API key
DEEPSEEK_API_KEY=sk-...

# Storage backend: local | github | demo
# When unset, auto-detects: GITHUB_TOKEN present → github, dev → local, else demo
STORAGE=local

# GitHub fine-grained PAT (contents read/write, single repo)
GITHUB_TOKEN=github_pat_...

# GitHub repository info (used by file tools)
GITHUB_REPO_OWNER=LikeDreamwalker
GITHUB_REPO_NAME=Aftrbrez

# Demo data URL (only used when STORAGE=demo or auto-detected as demo)
# BENCHMARK_BASE_URL=https://raw.githubusercontent.com/previously-lab/benchmark-data/main
